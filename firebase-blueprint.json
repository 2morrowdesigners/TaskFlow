{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task to be completed",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the task" },
        "description": { "type": "string", "description": "Detailed notes about the task" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"], "description": "Current state of the task" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "Importance of the task" },
        "dueDate": { "type": "string", "format": "date-time", "description": "When the task is due" },
        "category": { "type": "string", "description": "Category ID or name" },
        "uid": { "type": "string", "description": "Owner of the task" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "completedAt": { "type": ["string", "null"], "format": "date-time", "description": "When the task was completed" },
        "notified": { "type": "boolean", "description": "Whether the user has been notified" }
      },
      "required": ["title", "status", "uid", "createdAt"]
    },
    "Followup": {
      "title": "Followup",
      "description": "A record of a follow-up action",
      "type": "object",
      "properties": {
        "contactName": { "type": "string", "description": "Who to follow up with" },
        "notes": { "type": "string", "description": "What happened or needs to happen" },
        "followupDate": { "type": "string", "format": "date-time", "description": "When to follow up" },
        "status": { "type": "string", "enum": ["scheduled", "completed"], "description": "Status of the follow-up" },
        "uid": { "type": "string", "description": "Owner of the followup" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "completedAt": { "type": ["string", "null"], "format": "date-time", "description": "When the follow-up was completed" },
        "notified": { "type": "boolean", "description": "Whether the user has been notified" }
      },
      "required": ["contactName", "followupDate", "status", "uid", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A way to group tasks",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "color": { "type": "string", "description": "Hex color for the category" },
        "uid": { "type": "string", "description": "Owner of the category" }
      },
      "required": ["name", "uid"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": { "schema": "Task", "description": "User tasks" },
    "/followups/{followupId}": { "schema": "Followup", "description": "User follow-ups" },
    "/categories/{categoryId}": { "schema": "Category", "description": "User categories" }
  }
}
